<script>
    var lineChartData = {
        labels: ["Jan", "Feb", "Mar"],
        datasets: [{
            label: "신규 유저",
            borderColor: "rgba(75,192,192,1)",
            data: [28, 48, 40],
            fill: false,
            lineTension: 0.2
        }]
    };

    var ChartOptions = {
        maintainAspectRatio: false,
        responsive: true
    };

    var ctx = document.getElementById("lineChartjs");

    ctx && new Chart(ctx, {
        type: "line",
        data: lineChartData,
        options: ChartOptions
    });
</script>

    
   